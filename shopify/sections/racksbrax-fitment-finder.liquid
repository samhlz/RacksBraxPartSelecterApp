<style>
  .racksbrax-fitment-finder {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: #00495D;
    color: #ffffff;
    font-family: Arial, sans-serif;
  }

  .racksbrax-fitment-finder__continue {
    position: absolute;
    top: 24px;
    right: 28px;
    z-index: 2;
    color: #ffffff;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    opacity: 0.9;
  }

  .racksbrax-fitment-finder__continue:hover {
    opacity: 1;
  }

  .racksbrax-fitment-finder__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
    justify-items: center;
    min-height: 100svh;
    max-width: 1180px;
    box-sizing: border-box;
    margin: 0 auto;
    padding: 96px 24px;
    text-align: center;
  }

  .racksbrax-fitment-finder__finder-panel {
    grid-column: 1;
    grid-row: 1;
  }

  .racksbrax-fitment-finder__card-kicker {
    width: 100%;
    max-width: 760px;
    margin: 0 auto 18px;
    color: #ffffff;
    font-size: clamp(44px, 7vw, 82px);
    font-weight: 700;
    line-height: 0.95;
    text-align: center;
  }

  .racksbrax-fitment-finder__finder-panel {
    width: 100%;
    max-width: 760px;
  }

  .racksbrax-fitment-finder__card {
    width: 100%;
    max-width: 760px;
    box-sizing: border-box;
    margin-top: 0;
    padding: 28px;
    border-radius: 24px;
    background: #ffffff;
    color: #1d1d1d;
    text-align: left;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.14);
  }

  .racksbrax-fitment-finder__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 16px;
  }

  .racksbrax-fitment-finder__grid > div {
    min-width: 0;
  }

  .racksbrax-fitment-finder label {
    display: block;
    margin-bottom: 8px;
    font-size: 18px;
    font-weight: 700;
  }

  .racksbrax-fitment-finder select {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding: 15px 14px;
    border: 1px solid #bbb;
    border-radius: 12px;
    background: #ffffff;
    font-size: 16px;
    text-overflow: ellipsis;
  }

  .racksbrax-fitment-finder__result {
    margin-top: 24px;
    padding: 18px;
    border-radius: 16px;
    background: #f3f3f3;
    line-height: 1.45;
  }

  .racksbrax-fitment-finder__result-header h3 {
    margin: 0;
    font-size: 22px;
  }

  .racksbrax-fitment-finder__result-header p {
    margin: 8px 0 0;
    color: #4d4d4d;
  }

  .racksbrax-fitment-finder__note {
    margin: 16px 0;
    padding: 12px 14px;
    border-left: 4px solid #B8AB17;
    border-radius: 8px;
    background: #fffbea;
    color: #333333;
  }

  .racksbrax-fitment-finder__product-results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }

  .racksbrax-fitment-finder__product-card {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    padding: 14px;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
  }

  .racksbrax-fitment-finder__product-card:hover {
    border-color: #00495D;
  }

  .racksbrax-fitment-finder__product-image {
    width: 96px;
    aspect-ratio: 1;
    object-fit: contain;
    border-radius: 8px;
    background: #f7f7f7;
  }

  .racksbrax-fitment-finder__product-card-copy {
    min-width: 0;
  }

  .racksbrax-fitment-finder__product-label {
    margin: 0 0 8px;
    color: #00495D;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .racksbrax-fitment-finder__product-card h4 {
    margin: 0;
    font-size: 18px;
  }

  .racksbrax-fitment-finder__price {
    margin: 8px 0 0;
    color: #555555;
    font-weight: 700;
  }

  .racksbrax-fitment-finder__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 12px;
    margin-top: 18px;
  }

  .racksbrax-fitment-finder__actions button {
    width: 100%;
    box-sizing: border-box;
    border: none;
    border-radius: 12px;
    color: #ffffff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .racksbrax-fitment-finder__actions button:disabled {
    background: #999999;
    cursor: not-allowed;
  }

  .racksbrax-fitment-finder__primary-action {
    grid-column: 1 / -1;
    padding: 20px 18px;
    background: #B8AB17;
    font-size: 20px;
  }

  .racksbrax-fitment-finder__secondary-action {
    padding: 13px 12px;
    background: #111111;
    font-size: 15px;
  }

  .racksbrax-fitment-finder__action-status {
    min-height: 20px;
    margin: 10px 0 0;
    color: #00495D;
    font-weight: 700;
  }

  .racksbrax-fitment-finder__action-status.is-error {
    color: #b42318;
  }

  .racksbrax-fitment-finder__missing-link {
    margin: 14px 0 0;
    color: #666666;
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .racksbrax-fitment-finder__inner {
      padding-top: 96px;
    }

    .racksbrax-fitment-finder h1 {
      font-size: 46px;
    }

    .racksbrax-fitment-finder__grid {
      grid-template-columns: 1fr;
    }

    .racksbrax-fitment-finder__actions,
    .racksbrax-fitment-finder__product-card {
      grid-template-columns: 1fr;
    }

    .racksbrax-fitment-finder__product-image {
      width: 100%;
      max-height: 180px;
    }
  }

</style>

<section
  class="racksbrax-fitment-finder"
  data-racksbrax-fitment-finder
  data-fitments-url="{{ 'fitments_product_columns_with_urls.csv' | asset_url }}"
  data-unavailable-message="{{ section.settings.unavailable_message | escape }}"
  data-recommendation-heading="{{ section.settings.recommendation_heading | escape }}"
  data-recommendation-copy="{{ section.settings.recommendation_copy | escape }}"
  data-buy-now-label="{{ section.settings.buy_now_label | escape }}"
  data-add-to-cart-label="{{ section.settings.add_to_cart_label | escape }}"
  data-brand-placeholder="{{ section.settings.brand_placeholder | escape }}"
  data-model-placeholder="{{ section.settings.model_placeholder | escape }}"
  data-initial-result="{{ section.settings.initial_result | escape }}"
  data-model-prompt="{{ section.settings.model_prompt | escape }}"
  data-no-awnings-message="{{ section.settings.no_awnings_message | escape }}"
  data-load-error-message="{{ section.settings.load_error_message | escape }}"
  data-product-label="{{ section.settings.product_label | escape }}"
  data-loading-price-label="{{ section.settings.loading_price_label | escape }}"
  data-price-coming-soon-label="{{ section.settings.price_coming_soon_label | escape }}"
  data-missing-link-label="{{ section.settings.missing_link_label | escape }}"
  data-adding-to-cart-message="{{ section.settings.adding_to_cart_message | escape }}"
  data-added-to-cart-message="{{ section.settings.added_to_cart_message | escape }}"
>
  <a class="racksbrax-fitment-finder__continue" href="{{ section.settings.continue_url }}">
    {{ section.settings.continue_label }}
  </a>

  <div class="racksbrax-fitment-finder__inner">
    <div class="racksbrax-fitment-finder__finder-panel">
      <p class="racksbrax-fitment-finder__card-kicker">{{ section.settings.finder_kicker | escape }}</p>

      <div class="racksbrax-fitment-finder__card">
        <div class="racksbrax-fitment-finder__grid">
          <div>
            <label for="RacksBraxBrand-{{ section.id }}">{{ section.settings.brand_label | escape }}</label>
            <select id="RacksBraxBrand-{{ section.id }}" data-brand-select>
              <option value="">{{ section.settings.brand_placeholder | escape }}</option>
            </select>
          </div>

          <div>
            <label for="RacksBraxModel-{{ section.id }}">{{ section.settings.model_label | escape }}</label>
            <select id="RacksBraxModel-{{ section.id }}" data-model-select disabled>
              <option value="">{{ section.settings.model_placeholder | escape }}</option>
            </select>
          </div>
        </div>

        <div class="racksbrax-fitment-finder__result" data-result>
          {{ section.settings.initial_result | escape }}
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'racksbrax-fitment-finder.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "RacksBrax fitment finder",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "finder_kicker",
      "label": "Finder heading",
      "default": "I have"
    },
    {
      "type": "text",
      "id": "brand_label",
      "label": "Brand label",
      "default": "Brand"
    },
    {
      "type": "text",
      "id": "brand_placeholder",
      "label": "Brand placeholder",
      "default": "Select brand"
    },
    {
      "type": "text",
      "id": "model_label",
      "label": "Model label",
      "default": "Model"
    },
    {
      "type": "text",
      "id": "model_placeholder",
      "label": "Model placeholder",
      "default": "Select model"
    },
    {
      "type": "text",
      "id": "initial_result",
      "label": "Initial result text",
      "default": "Tell us what awning you have to see your recommended RacksBrax setup."
    },
    {
      "type": "text",
      "id": "model_prompt",
      "label": "Model prompt text",
      "default": "Select a model to see what you need."
    },
    {
      "type": "text",
      "id": "recommendation_heading",
      "label": "Recommendation heading",
      "default": "Your recommended RacksBrax setup"
    },
    {
      "type": "text",
      "id": "recommendation_copy",
      "label": "Recommendation copy",
      "default": "Based on your awning selection, these are the parts you need."
    },
    {
      "type": "text",
      "id": "product_label",
      "label": "Product card label",
      "default": "Required product"
    },
    {
      "type": "text",
      "id": "loading_price_label",
      "label": "Loading price label",
      "default": "Loading price"
    },
    {
      "type": "text",
      "id": "price_coming_soon_label",
      "label": "Price unavailable label",
      "default": "Price coming soon"
    },
    {
      "type": "text",
      "id": "missing_link_label",
      "label": "Missing product link label",
      "default": "Product page coming soon"
    },
    {
      "type": "text",
      "id": "buy_now_label",
      "label": "Buy now button label",
      "default": "Buy now"
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Add to cart button label",
      "default": "Add to cart"
    },
    {
      "type": "text",
      "id": "adding_to_cart_message",
      "label": "Adding to cart message",
      "default": "Adding setup to cart..."
    },
    {
      "type": "text",
      "id": "added_to_cart_message",
      "label": "Added to cart message",
      "default": "Added to cart."
    },
    {
      "type": "text",
      "id": "unavailable_message",
      "label": "Unavailable fitment message",
      "default": "we don't fitt. :(... yet \uD83D\uDC40"
    },
    {
      "type": "text",
      "id": "no_awnings_message",
      "label": "No awnings loaded message",
      "default": "No awnings loaded. Check that fitments_product_columns_with_urls.csv is uploaded to theme assets."
    },
    {
      "type": "text",
      "id": "load_error_message",
      "label": "Load error message",
      "default": "Could not load fitment data. Check that fitments_product_columns_with_urls.csv is uploaded to theme assets."
    },
    {
      "type": "text",
      "id": "continue_label",
      "label": "Continue link label",
      "default": "Continue to site"
    },
    {
      "type": "url",
      "id": "continue_url",
      "label": "Continue link URL"
    }
  ],
  "presets": [
    {
      "name": "RacksBrax fitment finder"
    }
  ]
}
{% endschema %}

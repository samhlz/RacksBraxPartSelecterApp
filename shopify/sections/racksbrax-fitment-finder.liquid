<style>
  .racksbrax-fitment-finder {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: #00495D;
    color: #ffffff;
    font-family: Arial, sans-serif;
  }

  .racksbrax-fitment-finder__continue {
    position: absolute;
    top: 24px;
    right: 28px;
    z-index: 2;
    color: #ffffff;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    opacity: 0.9;
  }

  .racksbrax-fitment-finder__continue:hover {
    opacity: 1;
  }

  .racksbrax-fitment-finder__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
    justify-items: center;
    min-height: 100svh;
    max-width: 1180px;
    box-sizing: border-box;
    margin: 0 auto;
    padding: 96px 24px;
    text-align: center;
  }

  .racksbrax-fitment-finder__intro,
  .racksbrax-fitment-finder__finder-panel {
    grid-column: 1;
    grid-row: 1;
  }

  .racksbrax-fitment-finder__intro {
    max-width: 820px;
    color: #ffffff;
    opacity: 1;
    transform: translateY(0) scale(1);
    visibility: visible;
    transition:
      opacity 0.7s ease,
      transform 0.7s ease,
      visibility 0s linear 0s;
  }

  .racksbrax-fitment-finder__eyebrow {
    margin: 0 0 16px;
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .racksbrax-fitment-finder h1 {
    max-width: 820px;
    margin: 0 auto;
    color: #ffffff;
    font-size: clamp(42px, 6vw, 76px);
    font-weight: 700;
    line-height: 0.95;
    opacity: 1;
  }

  .racksbrax-fitment-finder__intro-copy {
    max-width: 560px;
    margin: 24px auto 0;
    color: #ffffff;
    font-size: 20px;
    line-height: 1.45;
  }

  .racksbrax-fitment-finder__start-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 28px;
    padding: 14px 22px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 999px;
    background: #ffffff;
    color: #00495D;
    font: inherit;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
  }

  .racksbrax-fitment-finder__card-kicker {
    width: 100%;
    max-width: 760px;
    margin: 0 auto 18px;
    color: #ffffff;
    font-size: clamp(44px, 7vw, 82px);
    font-weight: 700;
    line-height: 0.95;
    text-align: center;
  }

  .racksbrax-fitment-finder__finder-panel {
    width: 100%;
    max-width: 760px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(18px) scale(0.98);
    visibility: hidden;
    transition:
      opacity 0.7s ease,
      transform 0.7s ease,
      visibility 0s linear 0.7s;
  }

  .racksbrax-fitment-finder.is-finder-revealed .racksbrax-fitment-finder__intro {
    opacity: 0;
    visibility: hidden;
    transform: translateY(-18px) scale(0.98);
    transition:
      opacity 0.7s ease,
      transform 0.7s ease,
      visibility 0s linear 0.7s;
  }

  .racksbrax-fitment-finder.is-finder-revealed .racksbrax-fitment-finder__finder-panel {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
    visibility: visible;
    transition:
      opacity 0.7s ease,
      transform 0.7s ease,
      visibility 0s linear 0s;
  }

  .racksbrax-fitment-finder__card {
    width: 100%;
    max-width: 760px;
    box-sizing: border-box;
    margin-top: 0;
    padding: 28px;
    border-radius: 24px;
    background: #ffffff;
    color: #1d1d1d;
    text-align: left;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.14);
  }

  .racksbrax-fitment-finder__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 16px;
  }

  .racksbrax-fitment-finder__grid > div {
    min-width: 0;
  }

  .racksbrax-fitment-finder label {
    display: block;
    margin-bottom: 8px;
    font-size: 18px;
    font-weight: 700;
  }

  .racksbrax-fitment-finder select {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding: 15px 14px;
    border: 1px solid #bbb;
    border-radius: 12px;
    background: #ffffff;
    font-size: 16px;
    text-overflow: ellipsis;
  }

  .racksbrax-fitment-finder__result {
    margin-top: 24px;
    padding: 18px;
    border-radius: 16px;
    background: #f3f3f3;
    line-height: 1.45;
  }

  .racksbrax-fitment-finder__result-header h3 {
    margin: 0;
    font-size: 22px;
  }

  .racksbrax-fitment-finder__result-header p {
    margin: 8px 0 0;
    color: #4d4d4d;
  }

  .racksbrax-fitment-finder__selected-awning {
    margin: 16px 0;
    padding: 12px 14px;
    border-radius: 10px;
    background: #ffffff;
  }

  .racksbrax-fitment-finder__product-results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }

  .racksbrax-fitment-finder__product-card {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    padding: 14px;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
  }

  .racksbrax-fitment-finder__product-card:hover {
    border-color: #00495D;
  }

  .racksbrax-fitment-finder__product-image {
    width: 96px;
    aspect-ratio: 1;
    object-fit: contain;
    border-radius: 8px;
    background: #f7f7f7;
  }

  .racksbrax-fitment-finder__product-card-copy {
    min-width: 0;
  }

  .racksbrax-fitment-finder__product-label {
    margin: 0 0 8px;
    color: #00495D;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .racksbrax-fitment-finder__product-card h4 {
    margin: 0;
    font-size: 18px;
  }

  .racksbrax-fitment-finder__price {
    margin: 8px 0 0;
    color: #555555;
    font-weight: 700;
  }

  .racksbrax-fitment-finder__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 12px;
    margin-top: 18px;
  }

  .racksbrax-fitment-finder__actions button {
    width: 100%;
    box-sizing: border-box;
    border: none;
    border-radius: 12px;
    color: #ffffff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .racksbrax-fitment-finder__actions button:disabled {
    background: #999999;
    cursor: not-allowed;
  }

  .racksbrax-fitment-finder__primary-action {
    grid-column: 1 / -1;
    padding: 20px 18px;
    background: #00495D;
    font-size: 20px;
  }

  .racksbrax-fitment-finder__secondary-action {
    padding: 13px 12px;
    background: #111111;
    font-size: 15px;
  }

  .racksbrax-fitment-finder__action-status {
    min-height: 20px;
    margin: 10px 0 0;
    color: #00495D;
    font-weight: 700;
  }

  .racksbrax-fitment-finder__action-status.is-error {
    color: #b42318;
  }

  .racksbrax-fitment-finder__missing-link {
    margin: 14px 0 0;
    color: #666666;
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .racksbrax-fitment-finder__inner {
      padding-top: 96px;
    }

    .racksbrax-fitment-finder h1 {
      font-size: 46px;
    }

    .racksbrax-fitment-finder__grid {
      grid-template-columns: 1fr;
    }

    .racksbrax-fitment-finder__actions,
    .racksbrax-fitment-finder__product-card {
      grid-template-columns: 1fr;
    }

    .racksbrax-fitment-finder__product-image {
      width: 100%;
      max-height: 180px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .racksbrax-fitment-finder__intro {
      display: none;
    }

    .racksbrax-fitment-finder__finder-panel {
      opacity: 1;
      pointer-events: auto;
      transform: none;
      visibility: visible;
    }
  }
</style>

<section
  class="racksbrax-fitment-finder"
  data-racksbrax-fitment-finder
  data-fitments-url="{{ 'fitments_product_columns_with_urls.csv' | asset_url }}"
>
  <a class="racksbrax-fitment-finder__continue" href="{{ section.settings.continue_url }}">
    {{ section.settings.continue_label }}
  </a>

  <div class="racksbrax-fitment-finder__inner">
    <div class="racksbrax-fitment-finder__intro">
      <p class="racksbrax-fitment-finder__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h1>{{ section.settings.heading | escape }}</h1>
      <p class="racksbrax-fitment-finder__intro-copy">{{ section.settings.intro_copy | escape }}</p>
      <button class="racksbrax-fitment-finder__start-button" type="button" data-reveal-finder>
        {{ section.settings.start_button_label | escape }}
      </button>
    </div>

    <div class="racksbrax-fitment-finder__finder-panel">
      <p class="racksbrax-fitment-finder__card-kicker">{{ section.settings.finder_kicker | escape }}</p>

      <div class="racksbrax-fitment-finder__card">
        <div class="racksbrax-fitment-finder__grid">
          <div>
            <label for="RacksBraxBrand-{{ section.id }}">Brand</label>
            <select id="RacksBraxBrand-{{ section.id }}" data-brand-select>
              <option value="">Select brand</option>
            </select>
          </div>

          <div>
            <label for="RacksBraxModel-{{ section.id }}">Model</label>
            <select id="RacksBraxModel-{{ section.id }}" data-model-select disabled>
              <option value="">Select model</option>
            </select>
          </div>
        </div>

        <div class="racksbrax-fitment-finder__result" data-result>
          Tell us what awning you have to see your recommended RacksBrax setup.
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'racksbrax-fitment-finder.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "RacksBrax fitment finder",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "RacksBrax Fitment Finder"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quick release system for awnings and accessories."
    },
    {
      "type": "text",
      "id": "intro_copy",
      "label": "Intro copy",
      "default": "Tell us what awning you have."
    },
    {
      "type": "text",
      "id": "start_button_label",
      "label": "Start button label",
      "default": "Find my awning"
    },
    {
      "type": "text",
      "id": "finder_kicker",
      "label": "Finder heading",
      "default": "I have"
    },
    {
      "type": "text",
      "id": "continue_label",
      "label": "Continue link label",
      "default": "Continue to site"
    },
    {
      "type": "url",
      "id": "continue_url",
      "label": "Continue link URL"
    }
  ],
  "presets": [
    {
      "name": "RacksBrax fitment finder"
    }
  ]
}
{% endschema %}

<style>
  .racksbrax-fitment-finder {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: #00495D;
    color: #ffffff;
    font-family: Arial, sans-serif;
  }

  .racksbrax-fitment-finder__continue {
    position: absolute;
    top: 24px;
    right: 28px;
    z-index: 2;
    color: #ffffff;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    opacity: 0.9;
  }

  .racksbrax-fitment-finder__continue:hover {
    opacity: 1;
  }

  .racksbrax-fitment-finder__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
    justify-items: center;
    min-height: 100svh;
    max-width: 1180px;
    box-sizing: border-box;
    margin: 0 auto;
    padding: 96px 24px;
    text-align: center;
  }

  .racksbrax-fitment-finder__finder-panel {
    grid-column: 1;
    grid-row: 1;
  }

  .racksbrax-fitment-finder__card-kicker {
    width: 100%;
    max-width: 760px;
    margin: 0 auto 18px;
    color: #ffffff;
    font-size: clamp(44px, 7vw, 82px);
    font-weight: 700;
    line-height: 0.95;
    text-align: center;
  }

  .racksbrax-fitment-finder__finder-panel {
    width: 100%;
    max-width: 760px;
  }

  .racksbrax-fitment-finder__card {
    width: 100%;
    max-width: 760px;
    box-sizing: border-box;
    margin-top: 0;
    padding: 28px;
    border-radius: 24px;
    background: #ffffff;
    color: #1d1d1d;
    text-align: left;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.14);
  }

  .racksbrax-fitment-finder__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 16px;
  }

  .racksbrax-fitment-finder__grid > div {
    min-width: 0;
  }

  .racksbrax-fitment-finder label {
    display: block;
    margin-bottom: 8px;
    font-size: 18px;
    font-weight: 700;
  }

  .racksbrax-fitment-finder select {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding: 15px 14px;
    border: 1px solid #bbb;
    border-radius: 12px;
    background: #ffffff;
    font-size: 16px;
    text-overflow: ellipsis;
  }

  .racksbrax-fitment-finder__missing-brand-form {
    margin-top: 20px;
    padding: 18px;
    border-radius: 16px;
    background: #f3f3f3;
    overflow: hidden;
  }

  .racksbrax-fitment-finder__missing-brand-form[hidden] {
    display: none;
  }

  .racksbrax-fitment-finder__missing-brand-track {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    width: 200%;
    transition: transform 260ms ease;
  }

  .racksbrax-fitment-finder__missing-brand-form.is-acknowledgement-open .racksbrax-fitment-finder__missing-brand-track {
    transform: translateX(-50%);
  }

  .racksbrax-fitment-finder__missing-brand-panel {
    min-width: 0;
    box-sizing: border-box;
    padding-right: 18px;
  }

  .racksbrax-fitment-finder__missing-brand-panel + .racksbrax-fitment-finder__missing-brand-panel {
    padding-right: 0;
    padding-left: 18px;
  }

  .racksbrax-fitment-finder__missing-brand-form.is-acknowledgement-open .racksbrax-fitment-finder__missing-brand-panel:first-child {
    opacity: 0;
    pointer-events: none;
  }

  .racksbrax-fitment-finder__missing-brand-form p {
    margin: 0 0 16px;
    color: #4d4d4d;
  }

  .racksbrax-fitment-finder__missing-brand-form input,
  .racksbrax-fitment-finder__missing-brand-form textarea {
    width: 100%;
    box-sizing: border-box;
    margin-bottom: 14px;
    padding: 14px;
    border: 1px solid #bbb;
    border-radius: 12px;
    background: #ffffff;
    font: inherit;
  }

  .racksbrax-fitment-finder__missing-brand-form button {
    width: 100%;
    padding: 14px 18px;
    border: none;
    border-radius: 12px;
    background: #B8AB17;
    color: #ffffff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .racksbrax-fitment-finder__form-status {
    margin-top: 12px;
    color: #00495D;
    font-weight: 700;
  }

  .racksbrax-fitment-finder__form-status.is-error {
    color: #b42318;
  }

  .racksbrax-fitment-finder__result {
    margin-top: 24px;
    padding: 18px;
    border-radius: 16px;
    background: #f3f3f3;
    line-height: 1.45;
    overflow: hidden;
  }

  .racksbrax-fitment-finder__result[hidden] {
    display: none;
  }

  .racksbrax-fitment-finder__slide {
    overflow: hidden;
  }

  .racksbrax-fitment-finder__slide-track {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    width: 200%;
    transition: transform 260ms ease;
  }

  .racksbrax-fitment-finder__result.is-email-reminder-open .racksbrax-fitment-finder__slide-track {
    transform: translateX(-50%);
  }

  .racksbrax-fitment-finder__slide-panel {
    min-width: 0;
    box-sizing: border-box;
    padding-right: 18px;
  }

  .racksbrax-fitment-finder__slide-panel + .racksbrax-fitment-finder__slide-panel {
    padding-right: 0;
    padding-left: 18px;
  }

  .racksbrax-fitment-finder__result.is-email-reminder-open .racksbrax-fitment-finder__slide-panel:first-child {
    opacity: 0;
    pointer-events: none;
  }

  .racksbrax-fitment-finder__result-header h3 {
    margin: 0;
    font-size: 22px;
  }

  .racksbrax-fitment-finder__result-header p {
    margin: 8px 0 0;
    color: #4d4d4d;
  }

  .racksbrax-fitment-finder__note {
    margin: 16px 0;
    padding: 12px 14px;
    border-left: 4px solid #B8AB17;
    border-radius: 8px;
    background: #fffbea;
    color: #333333;
  }

  .racksbrax-fitment-finder__product-results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }

  .racksbrax-fitment-finder__product-card {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    padding: 14px;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
  }

  .racksbrax-fitment-finder__product-card:hover {
    border-color: #00495D;
  }

  .racksbrax-fitment-finder__product-image {
    width: 96px;
    aspect-ratio: 1;
    object-fit: contain;
    border-radius: 8px;
    background: #f7f7f7;
  }

  .racksbrax-fitment-finder__product-card-copy {
    min-width: 0;
  }

  .racksbrax-fitment-finder__product-label {
    margin: 0 0 8px;
    color: #00495D;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .racksbrax-fitment-finder__product-card h4 {
    margin: 0;
    font-size: 18px;
  }

  .racksbrax-fitment-finder__price {
    margin: 8px 0 0;
    color: #555555;
    font-weight: 700;
  }

  .racksbrax-fitment-finder__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 12px;
    margin-top: 18px;
  }

  .racksbrax-fitment-finder__actions button {
    width: 100%;
    box-sizing: border-box;
    border: none;
    border-radius: 12px;
    color: #ffffff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .racksbrax-fitment-finder__actions button:disabled {
    background: #999999;
    cursor: not-allowed;
  }

  .racksbrax-fitment-finder__primary-action {
    grid-column: 1 / -1;
    padding: 20px 18px;
    background: #B8AB17;
    font-size: 20px;
  }

  .racksbrax-fitment-finder__secondary-action {
    grid-column: 1 / -1;
    padding: 13px 12px;
    background: #111111;
    font-size: 15px;
  }

  .racksbrax-fitment-finder__email-action {
    grid-column: 1 / -1;
    padding: 13px 12px;
    background: #00495D;
    font-size: 15px;
  }

  .racksbrax-fitment-finder__email-reminder {
    background: #f3f3f3;
  }

  .racksbrax-fitment-finder__email-reminder p {
    margin: 0 0 16px;
    color: #4d4d4d;
  }

  .racksbrax-fitment-finder__email-reminder input {
    width: 100%;
    box-sizing: border-box;
    margin-bottom: 14px;
    padding: 14px;
    border: 1px solid #bbb;
    border-radius: 12px;
    background: #ffffff;
    font: inherit;
  }

  .racksbrax-fitment-finder__email-reminder button {
    width: 100%;
    padding: 14px 18px;
    border: none;
    border-radius: 12px;
    background: #B8AB17;
    color: #ffffff;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .racksbrax-fitment-finder__email-reminder .racksbrax-fitment-finder__back-action {
    display: inline-grid;
    width: 42px;
    height: 42px;
    place-items: center;
    margin-bottom: 16px;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: #ffffff;
    color: #00495D;
    font-size: 28px;
    line-height: 1;
    font-weight: 700;
    cursor: pointer;
  }

  .racksbrax-fitment-finder__action-status {
    min-height: 20px;
    margin: 10px 0 0;
    color: #00495D;
    font-weight: 700;
  }

  .racksbrax-fitment-finder__action-status.is-error {
    color: #b42318;
  }

  .racksbrax-fitment-finder__missing-link {
    margin: 14px 0 0;
    color: #666666;
    font-weight: 700;
  }

  .racksbrax-fitment-finder__acknowledgement-card {
    min-height: 190px;
    display: grid;
    align-content: center;
    justify-items: start;
    color: #1d1d1d;
    animation: racksbrax-acknowledgement-slide-in 260ms ease;
  }

  .racksbrax-fitment-finder__acknowledgement-card h3 {
    margin: 0;
    color: #00495D;
    font-size: 26px;
  }

  .racksbrax-fitment-finder__acknowledgement-card p {
    margin: 8px 0 0;
    color: #4d4d4d;
  }

  .racksbrax-fitment-finder__acknowledgement-kicker {
    margin: 0 0 8px;
    color: #B8AB17;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @keyframes racksbrax-acknowledgement-slide-in {
    from {
      opacity: 0;
      transform: translateX(18px);
    }

    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @media (max-width: 820px) {
    .racksbrax-fitment-finder__inner {
      padding-top: 96px;
    }

    .racksbrax-fitment-finder h1 {
      font-size: 46px;
    }

    .racksbrax-fitment-finder__grid {
      grid-template-columns: 1fr;
    }

    .racksbrax-fitment-finder__actions,
    .racksbrax-fitment-finder__product-card {
      grid-template-columns: 1fr;
    }

    .racksbrax-fitment-finder__product-image {
      width: 100%;
      max-height: 180px;
    }
  }

</style>

<section
  id="racksbrax-fitment-finder"
  class="racksbrax-fitment-finder"
  data-racksbrax-fitment-finder
  data-fitments-url="{{ 'fitments_product_columns_with_urls.csv' | asset_url }}"
  data-unavailable-message="{{ section.settings.unavailable_message | escape }}"
  data-unavailable-template="{{ section.settings.unavailable_template | escape }}"
  data-recommendation-heading="{{ section.settings.recommendation_heading | escape }}"
  data-recommendation-copy="{{ section.settings.recommendation_copy | escape }}"
  data-buy-now-label="{{ section.settings.buy_now_label | escape }}"
  data-add-to-cart-label="{{ section.settings.add_to_cart_label | escape }}"
  data-brand-placeholder="{{ section.settings.brand_placeholder | escape }}"
  data-model-placeholder="{{ section.settings.model_placeholder | escape }}"
  data-initial-result="{{ section.settings.initial_result | escape }}"
  data-model-prompt="{{ section.settings.model_prompt | escape }}"
  data-recommendation-template="{{ section.settings.recommendation_template | escape }}"
  data-show-fitment-notes="{{ section.settings.show_fitment_notes }}"
  data-no-awnings-message="{{ section.settings.no_awnings_message | escape }}"
  data-load-error-message="{{ section.settings.load_error_message | escape }}"
  data-product-label="{{ section.settings.product_label | escape }}"
  data-loading-price-label="{{ section.settings.loading_price_label | escape }}"
  data-price-coming-soon-label="{{ section.settings.price_coming_soon_label | escape }}"
  data-missing-link-label="{{ section.settings.missing_link_label | escape }}"
  data-adding-to-cart-message="{{ section.settings.adding_to_cart_message | escape }}"
  data-added-to-cart-message="{{ section.settings.added_to_cart_message | escape }}"
  data-missing-brand-option="{{ section.settings.missing_brand_option | escape }}"
  data-missing-brand-success-message="{{ section.settings.missing_brand_success_message | escape }}"
  data-email-reminder-label="{{ section.settings.email_reminder_label | escape }}"
  data-email-reminder-message="{{ section.settings.email_reminder_message | escape }}"
  data-email-reminder-email-label="{{ section.settings.email_reminder_email_label | escape }}"
  data-email-reminder-email-placeholder="{{ section.settings.email_reminder_email_placeholder | escape }}"
  data-email-reminder-submit-label="{{ section.settings.email_reminder_submit_label | escape }}"
  data-email-reminder-back-label="{{ section.settings.email_reminder_back_label | escape }}"
  data-email-reminder-success-message="{{ section.settings.email_reminder_success_message | escape }}"
>
  <a class="racksbrax-fitment-finder__continue" href="{{ section.settings.continue_url }}">
    {{ section.settings.continue_label }}
  </a>

  <div class="racksbrax-fitment-finder__inner">
    <div class="racksbrax-fitment-finder__finder-panel">
      <p class="racksbrax-fitment-finder__card-kicker">{{ section.settings.finder_kicker | escape }}</p>

      <div class="racksbrax-fitment-finder__card">
        <div class="racksbrax-fitment-finder__grid">
          <div>
            <label for="RacksBraxBrand-{{ section.id }}">{{ section.settings.brand_label | escape }}</label>
            <select id="RacksBraxBrand-{{ section.id }}" data-brand-select>
              <option value="">{{ section.settings.brand_placeholder | escape }}</option>
            </select>
          </div>

          <div>
            <label for="RacksBraxModel-{{ section.id }}">{{ section.settings.model_label | escape }}</label>
            <select id="RacksBraxModel-{{ section.id }}" data-model-select disabled>
              <option value="">{{ section.settings.model_placeholder | escape }}</option>
            </select>
          </div>
        </div>

        <div class="racksbrax-fitment-finder__missing-brand-form" data-missing-brand-form hidden>
          <div class="racksbrax-fitment-finder__missing-brand-track">
            {% form 'contact', class: 'racksbrax-fitment-finder__missing-brand-panel' %}
              <input type="hidden" name="return_to" value="">
              <input type="hidden" name="contact[subject]" value="Works with brand request">
              <input type="hidden" name="contact[Request type]" value="Works with brand request">

              <p>{{ section.settings.missing_brand_message | default: "Enter your email, brand and awning name and we'll get back to you." | escape }}</p>

              <label for="RacksBraxMissingBrandName-{{ section.id }}">{{ section.settings.missing_brand_name_label | default: 'Name' | escape }}</label>
              <input
                id="RacksBraxMissingBrandName-{{ section.id }}"
                type="text"
                name="contact[name]"
                autocomplete="name"
                required
                placeholder="{{ section.settings.missing_brand_name_placeholder | default: 'Your name' | escape }}"
              >

              <label for="RacksBraxMissingBrandEmail-{{ section.id }}">{{ section.settings.missing_brand_email_label | default: 'Enter email' | escape }}</label>
              <input
                id="RacksBraxMissingBrandEmail-{{ section.id }}"
                type="email"
                name="contact[email]"
                autocomplete="email"
                required
                placeholder="{{ section.settings.missing_brand_email_placeholder | default: 'you@example.com' | escape }}"
              >

              <label for="RacksBraxMissingBrandDetails-{{ section.id }}">{{ section.settings.missing_brand_details_label | default: 'Enter brand and awning name' | escape }}</label>
              <textarea
                id="RacksBraxMissingBrandDetails-{{ section.id }}"
                name="contact[body]"
                rows="4"
                required
                placeholder="{{ section.settings.missing_brand_details_placeholder | default: 'Enter brand and awning name' | escape }}"
              ></textarea>

              <button type="submit">{{ section.settings.missing_brand_submit_label | escape }}</button>

              {% if form.errors %}
                <div class="racksbrax-fitment-finder__form-status is-error" aria-live="polite">{{ form.errors | default_errors }}</div>
              {% endif %}
            {% endform %}

            <div class="racksbrax-fitment-finder__missing-brand-panel racksbrax-fitment-finder__acknowledgement-card" aria-live="polite">
              <p class="racksbrax-fitment-finder__acknowledgement-kicker">Thanks</p>
              <h3>We've got it.</h3>
              <p>{{ section.settings.missing_brand_success_message | escape }}</p>
            </div>
          </div>
        </div>

        <div class="racksbrax-fitment-finder__result" data-result>
          {{ section.settings.initial_result | escape }}
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ 'racksbrax-fitment-finder.js' | asset_url }}" defer></script>

